apiVersion: v1
kind: Secret
metadata:
  name: ecommerce-secret
type: Opaque
stringData:
  # Database
  SPRING_DATASOURCE_PASSWORD: "change-me"
  
  # RabbitMQ
  RABBITMQ_PASSWORD: "change-me"
  
  # Keycloak
  KC_BOOTSTRAP_ADMIN_PASSWORD: "change-me"
  KEYCLOAK_CLIENT_SECRET: "change-me"
  
  # JWT
  JWT_SECRET: "change-me-minimum-32-characters-required"
  JWT_EXPIRATION: "3600000"
  JWT_REFRESH_EXPIRATION: "86400000"
  
  # Stripe (Get from https://dashboard.stripe.com/apikeys)
  STRIPE_API_KEY: "sk_test_your_stripe_api_key"
  STRIPE_WEBHOOK_SECRET: "whsec_your_webhook_secret"
  PAYMENT_ENCRYPTION_KEY: "change-me-32-characters-exactly"
  
  # Mail (Gmail App Password: https://myaccount.google.com/apppasswords)
  MAIL_PASSWORD: "your-gmail-app-password"
  
  # Twilio (Get from https://console.twilio.com/)
  TWILIO_AUTH_TOKEN: "your-twilio-auth-token"
