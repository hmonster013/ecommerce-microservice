# ===========================================
# E-COMMERCE MICROSERVICES ENVIRONMENT
# ===========================================

# Project Info
PROJECT_NAME=ecommerce-microservice
PROJECT_VERSION=0.0.1-SNAPSHOT

# ===========================================
# DATABASE CONFIGURATION
# ===========================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=25432
POSTGRES_DB=ecommerce
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password

# Individual Database Names
USER_SERVICE_DB=user_service_db
PRODUCT_CATALOG_DB=product_catalog_db
SHOPPING_CART_DB=shopping_cart_db
ORDER_SERVICE_DB=order_service_db
PAYMENT_SERVICE_DB=payment_service_db
NOTIFICATION_SERVICE_DB=notification_service_db

# ===========================================
# REDIS CONFIGURATION
# ===========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=16379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ===========================================
# KAFKA CONFIGURATION
# ===========================================
KAFKA_HOST=kafka
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Kafka KRaft Configuration
KAFKA_NODE_ID=1
KAFKA_PROCESS_ROLES=broker,controller
KAFKA_LISTENERS=PLAINTEXT://0.0.0.0:9092,CONTROLLER://0.0.0.0:9093
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:9092
KAFKA_CONTROLLER_LISTENER_NAMES=CONTROLLER
KAFKA_LISTENER_SECURITY_PROTOCOL_MAP=CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT
KAFKA_CONTROLLER_QUORUM_VOTERS=1@kafka:9093
KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR=1
KAFKA_TRANSACTION_STATE_LOG_MIN_ISR=1
KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS=0
KAFKA_NUM_PARTITIONS=3

# ===========================================
# RABBITMQ
# ===========================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_HOST_PORT=15672
RABBITMQ_MGMT_HOST_PORT=25672
RABBITMQ_USERNAME=user
RABBITMQ_PASSWORD=password

# ===========================================
# SERVICE DISCOVERY
# ===========================================
EUREKA_HOST=eureka-server
EUREKA_PORT=8761
EUREKA_URL=http://eureka-server:8761/eureka/

# ===========================================
# CONFIG SERVER
# ===========================================
CONFIG_SERVER_PORT=8071
CONFIG_SERVER_URL=http://config-server:8071

# ===========================================
# SERVICE PORTS
# ===========================================
API_GATEWAY_PORT=8080
EUREKA_SERVER_PORT=8761
USER_SERVICE_PORT=8081
PRODUCT_CATALOG_PORT=8082
SHOPPING_CART_PORT=8083
ORDER_SERVICE_PORT=8084
PAYMENT_SERVICE_PORT=8085
NOTIFICATION_SERVICE_PORT=8086


# ===========================================
# SECURITY CONFIGURATION
# ===========================================

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# Session Management
SESSION_TIMEOUT=1800
MAX_CONCURRENT_SESSIONS=3

# Rate Limiting — user-service & shopping-cart-service
RATE_LIMIT_ENABLED=true
LOGIN_RATE_LIMIT=5
REGISTRATION_RATE_LIMIT=3
GENERAL_RATE_LIMIT=100

# Rate Limiting — api-gateway (Bucket4j)
RATE_LIMIT_IP_CAPACITY=1000
RATE_LIMIT_IP_REFILL=1000
RATE_LIMIT_IP_PERIOD=1
RATE_LIMIT_USER_CAPACITY=10000
RATE_LIMIT_USER_REFILL=10000
RATE_LIMIT_USER_PERIOD=1

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost:8080

# Swagger Access
PERMIT_ALL_SWAGGER_PATHS=false

# ===========================================
# KEYCLOAK
# ===========================================
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
KEYCLOAK_HOST=keycloak
KEYCLOAK_PORT=8090
KEYCLOAK_REALM=ecommerce-realm
KEYCLOAK_SERVER_URL=http://keycloak:8080
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/ecommerce-realm
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/ecommerce-realm/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=api-gateway
KEYCLOAK_CLIENT_SECRET=api-gateway-secret-change-in-production

# ===========================================
# STRIPE CONFIGURATION
# ===========================================
STRIPE_ENABLED=true
STRIPE_API_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_API_VERSION=2023-10-16
STRIPE_SUCCESS_URL=http://localhost:3000/payment/success
STRIPE_CANCEL_URL=http://localhost:3000/payment/cancel

# ===========================================
# PAYMENT PROCESSING
# ===========================================
PAYMENT_TIMEOUT=30000
PAYMENT_RETRY_ATTEMPTS=3
PAYMENT_RETRY_DELAY=1000
PAYMENT_ENCRYPTION_KEY=your_32_character_encryption_key
WEBHOOK_TIMEOUT=10000

# ===========================================
# NOTIFICATION SERVICE CONFIGURATION
# ===========================================

# Gmail Configuration (for Email Notifications)
# Note: Use App Password instead of regular password
# Setup: Google Account > Security > 2-Step Verification > App passwords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
MAIL_TEST_CONNECTION=false

# Twilio Configuration (for SMS Notifications)
# Get these from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
# Optional: For delivery status webhooks
TWILIO_WEBHOOK_URL=

# Notification Settings
SMS_MOCK_MODE=true
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SMS_ENABLED=true

# Rate Limiting (messages per minute)
EMAIL_RATE_LIMIT=100
SMS_RATE_LIMIT=50

# Retry Configuration
EMAIL_MAX_RETRIES=3
SMS_MAX_RETRIES=3
EMAIL_RETRY_DELAY_SECONDS=60
SMS_RETRY_DELAY_SECONDS=120

# ===========================================
# LOGGING CONFIGURATION
# ===========================================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_SECURITY=INFO

# ===========================================
# DEVELOPMENT FLAGS
# ===========================================
SPRING_PROFILES_ACTIVE=docker
DEBUG_MODE=false
SWAGGER_ENABLED=true

# ===========================================
# OPENTELEMETRY CONFIGURATION
# ===========================================
# For Docker containers (using service names)
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4318
OTEL_LOGS_EXPORTER=none
